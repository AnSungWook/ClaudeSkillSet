{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npx:*)",
      "Bash(curl:*)"
    ]
  },
  "env": {
    "JIRA_PROJECT_KEY": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-merge.sh",
            "timeout": 5,
            "statusMessage": "Checking merge target branch..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"'\"$CLAUDE_NOTIFICATION\"'\" with title \"Claude Code\"' 2>/dev/null || notify-send \"Claude Code\" \"$CLAUDE_NOTIFICATION\" 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
